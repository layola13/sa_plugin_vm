{
  "schema": "sa.plugin/1",
  "name": "vm",
  "version": "0.1.0",
  "source": {
    "type": "local",
    "path": "."
  },
  "abi": {
    "plugin": 1,
    "saasm": ">=0.4.0",
    "symbols": "CLI-only"
  },
  "artifacts": {
    "linux-x86_64": {
      "path": "zig-out/lib/libvm.so"
    }
  },
  "interfaces": {},
  "skills": ["vm"],
  "permissions": {
    "fs": [
      { "op": "read", "path": "$PROJECT/**" },
      { "op": "write", "path": "$PROJECT/**" },
      { "op": "create", "path": "$PROJECT/**" },
      { "op": "delete", "path": "$PROJECT/**" },
      { "op": "metadata", "path": "$PROJECT/**" },
      { "op": "read", "path": "$SA_PLUGINS_HOME/**" },
      { "op": "metadata", "path": "$SA_PLUGINS_HOME/**" },
      { "op": "read", "path": "$HOME/.sa/std/**" },
      { "op": "metadata", "path": "$HOME/.sa/std/**" },
      { "op": "read", "path": "$SA_CACHE/**" },
      { "op": "write", "path": "$SA_CACHE/**" },
      { "op": "create", "path": "$SA_CACHE/**" }
    ],
    "net": [
      { "url": "https://example.com", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] },
      { "url": "https://api.example.com", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] },
      { "url": "http://localhost", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] },
      { "url": "http://127.0.0.1", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] },
      { "url": "http://localhost:18395", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] },
      { "url": "http://127.0.0.1:18395", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] },
      { "url": "http://[::1]", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] }
    ],
    "env": ["HOME", "SA_PLUGINS_HOME", "SA_STD_DIR", "SA_CACHE", "SA_*"],
    "process": {
      "spawn": true,
      "exec": [
        { "path": "/bin/echo", "args": ["*"] },
        { "path": "/usr/bin/echo", "args": ["*"] }
      ]
    }
  },
  "dependencies": {
    "http-client": {
      "version": ">=0.1.0",
      "abi": 1,
      "optional": true,
      "symbols": [
        "sa_http_client_new",
        "sa_http_client_req_new",
        "sa_http_client_req_add_header",
        "sa_http_client_req_set_body",
        "sa_http_client_req_send",
        "sa_http_client_resp_status",
        "sa_http_client_resp_get_header",
        "sa_http_client_resp_body_slice",
        "sa_http_client_resp_body_reader",
        "sa_http_client_resp_read_chunk",
        "sa_http_client_resp_free",
        "sa_http_client_body_reader_free",
        "sa_http_client_req_free",
        "sa_http_client_free"
      ]
    },
    "http-server": {
      "version": ">=0.1.0",
      "abi": 1,
      "optional": true,
      "symbols": [
        "sa_http_server_new",
        "sa_http_server_start",
        "sa_http_server_accept",
        "sa_http_server_req_get_method",
        "sa_http_server_req_get_path",
        "sa_http_server_req_get_header",
        "sa_http_server_req_get_body",
        "sa_http_server_req_free",
        "sa_http_server_resp_new",
        "sa_http_server_resp_send",
        "sa_http_server_resp_set_content_type",
        "sa_http_server_resp_free",
        "sa_http_server_resp_stream_new",
        "sa_http_server_resp_stream_write",
        "sa_http_server_resp_stream_flush",
        "sa_http_server_resp_stream_end",
        "sa_http_server_resp_stream_free",
        "sa_http_server_free"
      ]
    },
    "deno": {
      "version": ">=0.1.0",
      "abi": 1,
      "optional": true,
      "symbols": ["sa_deno_plugin_hostname"]
    },
    "node": {
      "version": ">=0.1.0",
      "abi": 1,
      "optional": true,
      "symbols": [
        "sa_node_plugin_os_cpus",
        "sa_node_plugin_timers_sleep",
        "sa_node_plugin_dgram_create",
        "sa_node_plugin_dgram_bind",
        "sa_node_plugin_dgram_send",
        "sa_node_plugin_dgram_recv",
        "sa_node_plugin_dgram_close"
      ]
    }
